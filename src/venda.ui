   <string notr="true">
#venda {
  background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0,
    stop:0 rgba(199, 199, 199, 255), stop:1 rgba(170, 170, 170, 255));
}
QPushButton {
  background-color: rgb(43, 132, 191);
  color: rgb(255, 255, 255);
  font-size: 13px;
  border-radius: 10px;
}
QPushButton:hover {
  background-color: rgb(13, 92, 161);
}
QPushButton:pressed {
  color: rgb(255, 255, 255);
  background-color: rgb(153, 193, 241);
  font-size: 13px;
  border-radius: 10px;
}
QPushButton:disabled {
  background-color: rgb(154, 153, 150);
}
QGroupBox {
  background-color: rgb(170, 170, 170);
  font: 700 9pt &quot;Segoe UI&quot;;
  font-size: 14px;
}
QTableView {
  background-color: #ffffff;
  alternate-background-color: #dce9f5;
  border: 1px solid #e2e8f0;
  border-radius: 6px;
  gridline-color: #e2e8f0;
  selection-background-color: rgb(43, 132, 191);
  selection-color: #ffffff;
  outline: none;
}
QHeaderView::section {
  background-color: #f1f5f9;
  color: #475569;
  font: 600 9pt &quot;Ubuntu&quot;;
  border: none;
  border-bottom: 2px solid #e2e8f0;
  border-right: 1px solid #e2e8f0;
  padding: 6px 10px;
}
QScrollBar:vertical {
  background: #f1f5f9;
  width: 8px;
  border-radius: 4px;
}
QScrollBar::handle:vertical {
  background: #cbd5e1;
  border-radius: 4px;
  min-height: 20px;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
  height: 0px;
}
QLineEdit {
  background-color: white;
  border: 1px solid rgb(175, 185, 205);
  border-radius: 6px;
  padding: 4px 8px;
  font-size: 12px;
  color: rgb(45, 55, 75);
}
QLineEdit:focus {
  border-color: rgb(43, 132, 191);
}
